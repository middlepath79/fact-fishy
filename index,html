    let deferredPrompt;
    const installPrompt = document.getElementById('installPrompt');
    const installBtn = document.getElementById('installBtn');
    const closeInstallBtn = document.getElementById('closeInstallBtn');
    
    window.addEventListener('beforeinstallprompt', (e) => {
        e.preventDefault();
        deferredPrompt = e;
        installPrompt.classList.add('show');
        document.getElementById('pwaStatus').textContent = 'Installable';
    });
    
    installBtn.addEventListener('click', async () => {
        if (deferredPrompt) {
            deferredPrompt.prompt();
            const { outcome } = await deferredPrompt.userChoice;
            if (outcome === 'accepted') {
                document.getElementById('pwaStatus').textContent = 'Installed ✓';
            }
            deferredPrompt = null;
            installPrompt.classList.remove('show');
        }
    });
    
    closeInstallBtn.addEventListener('click', () => {
        installPrompt.classList.remove('show');
    });
    
    // Detect if already installed
    window.addEventListener('appinstalled', () => {
        document.getElementById('pwaStatus').textContent = 'Installed ✓';
        installPrompt.classList.remove('show');
    });
    
    // ==================== REAL GLOBAL VISIT COUNTER ====================
    async function updateGlobalCounter() {
        const namespace = 'fact_or_fishy_ng';
        const key = 'total_visits';
        const sessionTracked = sessionStorage.getItem('global_visit_tracked');
        
        if (!sessionTracked) {
            try {
                const response = await fetch(`https://api.countapi.xyz/hit/${namespace}/${key}`);
                const data = await response.json();
                document.getElementById('globalVisitCount').textContent = data.value.toLocaleString();
                localStorage.setItem('global_total_visits', data.value);
                sessionStorage.setItem('global_visit_tracked', 'true');
            } catch(error) {
                const stored = localStorage.getItem('global_total_visits') || 1024;
                document.getElementById('globalVisitCount').textContent = stored.toLocaleString();
            }
        } else {
            const stored = localStorage.getItem('global_total_visits') || 1024;
            document.getElementById('globalVisitCount').textContent = stored.toLocaleString();
        }
    }
    
    function updateLocalCounter() {
        let visits = localStorage.getItem('factOrFishyLocalVisits') || 0;
        visits = parseInt(visits) + 1;
        localStorage.setItem('factOrFishyLocalVisits', visits);
        document.getElementById('localVisitCount').textContent = visits;
    }
    
