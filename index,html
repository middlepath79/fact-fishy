    ];

    const NIGERIAN_FALSE_MYTHS = [
        { text: "All Nigerians speak 'Nigerian' as their first language.", explanation: "FALSE! Nigeria has over 500 languages including Hausa, Igbo, Yoruba, and Pidgin." },
        { text: "The Benin Empire was located in modern-day Benin Republic.", explanation: "FALSE! The Benin Empire was in southern Nigeria (Edo State)." },
        { text: "Jollof rice originated in Nigeria.", explanation: "FALSE! Jollof originated in Senegal/Gambia — Nigeria made it world-famous!" },
        { text: "Lagos is Nigeria's capital city.", explanation: "FALSE! Abuja became the capital in 1991. Lagos is the former capital." }
    ];

    const AFRICAN_FALSE_MYTHS = [
        { text: "The pyramids in Egypt were built by slaves.", explanation: "FALSE! Evidence shows skilled, well-fed workers built the pyramids." },
        { text: "Africa is a country, not a continent.", explanation: "FALSE! Africa is a continent with 54 recognized countries." },
        { text: "All Africans live in poverty with no technology.", explanation: "FALSE! Africa has thriving tech hubs in Kenya, Nigeria, and South Africa." },
        { text: "Lion prides are always led by a male lion (the 'king').", explanation: "FALSE! Lion prides are matriarchal — females do most hunting and lead." },
        { text: "Zebras are white with black stripes.", explanation: "FALSE! Zebras are black with white stripes — their skin is black." }
    ];

    let allStatements = [];
    NIGERIAN_TRUE_FACTS.forEach(f => allStatements.push({ text: f.text, isFact: true, explanation: f.explanation }));
    AFRICAN_TRUE_FACTS.forEach(f => allStatements.push({ text: f.text, isFact: true, explanation: f.explanation }));
    NIGERIAN_FALSE_MYTHS.forEach(m => allStatements.push({ text: m.text, isFact: false, explanation: m.explanation }));
    AFRICAN_FALSE_MYTHS.forEach(m => allStatements.push({ text: m.text, isFact: false, explanation: m.explanation }));

    function shuffleArray(arr) {
        for (let i = arr.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [arr[i], arr[j]] = [arr[j], arr[i]];
        }
        return arr;
    }

    allStatements = shuffleArray(allStatements);

    let usedIndices = new Set();
    let nextIndexPointer = 0;
    
    function getNextUniqueStatement() {
        if (usedIndices.size >= allStatements.length) {
            usedIndices.clear();
            allStatements = shuffleArray(allStatements);
            nextIndexPointer = 0;
        }
        while (usedIndices.has(nextIndexPointer)) {
            nextIndexPointer = (nextIndexPointer + 1) % allStatements.length;
        }
        const statement = { ...allStatements[nextIndexPointer] };
        usedIndices.add(nextIndexPointer);
        nextIndexPointer = (nextIndexPointer + 1) % allStatements.length;
        return statement;
    }

    const DIFFICULTY_SETTINGS = {
        easy: { name: "🍃 EASY", basePoints: 8, streakBonus: 2, streakMultiplier: true, adFrequency: 8 },
        medium: { name: "⚡ MEDIUM", basePoints: 10, streakBonus: 5, streakMultiplier: true, adFrequency: 5 },
        hard: { name: "🔥 HARD", basePoints: 15, streakBonus: 0, streakMultiplier: false, adFrequency: 3 }
    };

    let currentDifficulty = "medium";
    let currentSettings = DIFFICULTY_SETTINGS.medium;
    let score = 0, streak = 0, guessed = false, currentStatement = null, statementNumber = 1, adCounter = 0;
    
    const soundManager = { playCorrect() {}, playWrong() {} };
    
    const statementEl = document.getElementById("statementText");
    const scoreSpan = document.getElementById("scoreValue");
    const streakSpan = document.getElementById("streakValue");
    const statementCountSpan = document.getElementById("statementCount");
    const guessFactBtn = document.getElementById("guessFactBtn");
    const guessFishyBtn = document.getElementById("guessFishyBtn");
    const feedbackArea = document.getElementById("feedbackArea");
    const nextBtn = document.getElementById("nextBtn");
    const resetBtn = document.getElementById("resetBtn");
    const shareXBtn = document.getElementById("shareXBtn");
    const shareWhatsAppBtn = document.getElementById("shareWhatsAppBtn");
    const difficultyBadge = document.getElementById("difficultyBadge");
    const flipCard = document.getElementById("flipCard");
    const answerBadge = document.getElementById("answerBadge");
    const explanationText = document.getElementById("explanationText");
    const resultBadge = document.getElementById("resultBadge");
    
    function shareOnX() {
        const text = encodeURIComponent(`🇳🇬 I scored ${score} points on Fact or Fishy? Nigerian & African Edition! Can you beat me? 🎓`);
        window.open(`https://twitter.com/intent/tweet?text=${text}&url=${window.location.href}`, '_blank');
    }
    
    function shareOnWhatsApp() {
        const text = encodeURIComponent(`🇳🇬 I scored ${score} points on Fact or Fishy? Nigerian & African Edition! Play here: ${window.location.href}`);
        window.open(`https://wa.me/?text=${text}`, '_blank');
    }
    
    shareXBtn.addEventListener('click', (e) => { e.preventDefault(); shareOnX(); });
    shareWhatsAppBtn.addEventListener('click', (e) => { e.preventDefault(); shareOnWhatsApp(); });
    
    function updateUI() {
        scoreSpan.textContent = score;
        streakSpan.textContent = streak;
        if (streak > 0 && streak % 5 === 0) {
            document.getElementById("streakValue").classList.add('streak-fire');
            setTimeout(() => document.getElementById("streakValue").classList.remove('streak-fire'), 500);
        }
    }
    
    function setDifficulty(difficulty) {
        currentDifficulty = difficulty;
        currentSettings = DIFFICULTY_SETTINGS[difficulty];
        difficultyBadge.textContent = currentSettings.name;
        document.querySelectorAll('.difficulty-btn').forEach(btn => btn.classList.remove('active'));
        document.querySelector(`.difficulty-btn[data-diff="${difficulty}"]`).classList.add('active');
        resetGame();
    }
    
    function loadStatement() {
        currentStatement = getNextUniqueStatement();
        statementEl.innerText = currentStatement.text;
        statementCountSpan.textContent = statementNumber;
        guessed = false;
        flipCard.classList.remove('flipped');
        guessFactBtn.disabled = false;
        guessFishyBtn.disabled = false;
        nextBtn.disabled = true;
        resultBadge.innerHTML = "";
        answerBadge.textContent = currentStatement.isFact ? "✅ FACT" : "🐟 FISHY";
        answerBadge.className = `answer-badge ${currentStatement.isFact ? 'answer-fact' : 'answer-fishy'}`;
        explanationText.textContent = currentStatement.explanation;
        feedbackArea.innerHTML = `🇳🇬 ${currentSettings.name} mode • Tap FACT or FISHY to guess!`;
    }
    
    function makeGuess(guessIsFact) {
        if (guessed) {
            feedbackArea.innerHTML = "⚠️ You already guessed! Click NEXT to continue.";
            return;
        }
        guessed = true;
        const isCorrect = (guessIsFact === currentStatement.isFact);
        let pointsEarned = 0;
        if (isCorrect) {
            pointsEarned = currentSettings.basePoints;
            if (currentSettings.streakMultiplier && streak > 0) {
                pointsEarned += Math.min(currentSettings.streakBonus * streak, 50);
            }
            score += pointsEarned;
            streak++;
            resultBadge.innerHTML = `🎉 CORRECT! +${pointsEarned} points! 🎉`;
            resultBadge.className = "result-badge result-correct";
            adCounter++;
            if (adCounter >= currentSettings.adFrequency) {
                adCounter = 0;
                try { (adsbygoogle = window.adsbygoogle || []).push({}); } catch(e) {}
            }
        } else {
            streak = 0;
            resultBadge.innerHTML = `❌ WRONG! It was ${currentStatement.isFact ? "FACT" : "FISHY"}. ❌`;
            resultBadge.className = "result-badge result-wrong";
        }
        updateUI();
        flipCard.classList.add('flipped');
        guessFactBtn.disabled = true;
        guessFishyBtn.disabled = true;
        nextBtn.disabled = false;
        feedbackArea.innerHTML = isCorrect ? `✅ CORRECT! +${pointsEarned} points! Streak: ${streak} 🔥` : `❌ INCORRECT! Read the explanation above!`;
    }
    
    function nextStatement() {
        if (!guessed) {
            feedbackArea.innerHTML = "👉 Make a guess first! Tap FACT or FISHY.";
            return;
        }
        statementNumber++;
        loadStatement();
    }
    
    function resetGame() {
        score = 0; streak = 0; adCounter = 0; statementNumber = 1;
        usedIndices.clear();
        allStatements = shuffleArray(allStatements);
        nextIndexPointer = 0;
        updateUI();
        loadStatement();
        feedbackArea.innerHTML = `🔄 Game reset! ${currentSettings.name} mode active. ${allStatements.length} facts ready! 🇳🇬`;
    }
    
    guessFactBtn.addEventListener("click", () => makeGuess(true));
    guessFishyBtn.addEventListener("click", () => makeGuess(false));
    nextBtn.addEventListener("click", nextStatement);
    resetBtn.addEventListener("click", resetGame);
    document.querySelectorAll('.difficulty-btn').forEach(btn => {
        btn.addEventListener('click', () => setDifficulty(btn.dataset.diff));
    });
    
    updateGlobalCounter();
    updateLocalCounter();
    loadStatement();
    
    // Register Service Worker for PWA
    if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js').then(reg => {
            console.log('Service Worker registered!');
            document.getElementById('pwaStatus').textContent = 'PWA Ready';
        }).catch(err => {
            console.log('Service Worker failed:', err);
        });
    }
</script>

<script>
    // Service Worker Code - This will be extracted to sw.js
    const swCode = `// Service Worker for Fact or Fishy? PWA
const CACHE_NAME = 'fact-or-fishy-v1';
const urlsToCache = [
    '/',
    '/index.html',
    'https://api.countapi.xyz'
];

self.addEventListener('install', event => {
    event.waitUntil(
        caches.open(CACHE_NAME)
            .then(cache => cache.addAll(urlsToCache))
    );
});

self.addEventListener('fetch', event => {
    event.respondWith(
        caches.match(event.request)
            .then(response => response || fetch(event.request))
    );
});

self.addEventListener('activate', event => {
    event.waitUntil(
        caches.keys().then(cacheNames => {
            return Promise.all(
                cacheNames.map(cache => {
                    if (cache !== CACHE_NAME) {
                        return caches.delete(cache);
                    }
                })
            );
        })
    );
});`;
    
    // Create and save service worker file
    const blob = new Blob([swCode], { type: 'application/javascript' });
    const link = document.createElement('a');
    link.href = URL.createObjectURL(blob);
    link.download = 'sw.js';
    link.click();
    
    // Manifest file creation
    const manifestCode = `{
    "name": "Fact or Fishy? Nigeria",
    "short_name": "Fact or Fishy",
    "description": "Test your knowledge about Nigeria and Africa!",
    "start_url": "/",
    "display": "standalone",
    "theme_color": "#008751",
    "background_color": "#0a4a2a",
    "icons": [
        {
            "src": "https://via.placeholder.com/192x192?text=FOF",
            "sizes": "192x192",
            "type": "image/png"
        },
        {
            "src": "https://via.placeholder.com/512x512?text=FOF",
            "sizes": "512x512",
            "type": "image/png"
        }
    ]
}`;
    
    const manifestBlob = new Blob([manifestCode], { type: 'application/json' });
    const manifestLink = document.createElement('a');
    manifestLink.href = URL.createObjectURL(manifestBlob);
    manifestLink.download = 'manifest.json';
    manifestLink.click();
    
    setTimeout(() => {
        alert('📱 PWA Files Downloaded!\n\n1. Save sw.js and manifest.json in the same folder as your HTML file\n2. Upload all 3 files to your hosting\n3. Your game is now installable as an app!');
    }, 1000);
</script>
